BasedOnStyle: Google
Language: Cpp
ColumnLimit: 100
IndentWidth: 4
UseTab: Never
SortIncludes: CaseSensitive
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^"ms/'
    Priority: 1
  - Regex: '^"'
    Priority: 2
  - Regex: '^<'
    Priority: 3
AllowShortFunctionsOnASingleLine: Empty
AlignEscapedNewlines: Left
