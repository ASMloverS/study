#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = C:\Tools\VS2022\Community\Common7\IDE\CommonExtensions\Microsoft\CMake\CMake\bin\cmake.exe --regenerate-during-build -SC:\Workspace\Repositories\study\aicode\mslang-c -BC:\Workspace\Repositories\study\aicode\mslang-c\build_clang
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = C:\Tools\VS2022\Community\Common7\IDE\CommonExtensions\Microsoft\CMake\Ninja\ninja.exe $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
